{
  "Benchmark": {
    "DefaultAgent": "opencode",
    "DefaultRepeats": 1,
    "DefaultTimeoutMinutes": 15,
    "ResultsDirectory": "results",
    "FixturesDirectory": "fixtures",
    "TasksDirectory": "tasks",
    "SkillsFilePath": "skills/AGENTS.md"
  },
  "Agents": {
    "opencode": {
      "Executable": "opencode",
      "Arguments": "run --format json --dangerously-skip-permissions",
      "Provider": "venice",
      "DefaultModel": "qwen/qwen-2.5-coder-32b-instruct"
    }
  },
  "Judge": {
    "Model": "qwen/qwq-32b",
    "Provider": "venice",
    "ApiKeyEnvironmentVariable": "VENICE_API_KEY",
    "ApiBaseUrl": "https://api.venice.ai/api/v1",
    "Repeats": 3
  },
  "Pricing": {
    "venice/qwen-2.5-coder-32b-instruct": { "inputPer1k": 0.0002, "outputPer1k": 0.0006 },
    "venice/qwq-32b": { "inputPer1k": 0.0003, "outputPer1k": 0.0009 },
    "venice/mistral-large-2411": { "inputPer1k": 0.002, "outputPer1k": 0.006 },
    "venice/deepseek-r1-671b": { "inputPer1k": 0.0008, "outputPer1k": 0.003 }
  },
  "Serilog": {
    "MinimumLevel": "Information"
  }
}
